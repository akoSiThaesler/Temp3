# Visual Studio
.vs/
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# JetBrains IDEs
.idea/

# macOS
.DS_Store

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Debug symbols
*.pdb

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln

# Microsoft Office temporary/lock files
~$*

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/*/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Generated HLOD data (produced by the HLOD system, not source)
*_HLOD*.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/*/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*

# Editor-only content (not real project assets)
Content/Developers/
Content/Collections/
Content/_GENERATED/

# UE Template Content (re-downloadable from Epic)
Content/StarterContent/
Content/VRTemplate/
Content/FirstPerson/
Content/FirstPersonArms/
Content/LevelPrototyping/
Content/Characters/

# Marketplace / Fab Asset Packs (re-downloadable)
Content/FactoryExteriorInteriorBundle/
Content/LeartesStudiosOffice/
Content/VigilanteContent/
Content/Fab/
Content/CorridorAssets/
Content/Elevator_corridor/
Content/QuantumCharacter/
Content/Laboratory/
